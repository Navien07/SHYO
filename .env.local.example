# Copy to .env.local and fill in values (never commit .env.local)
NEXT_PUBLIC_SANITY_PROJECT_ID=    # From manage.sanity.io project settings
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=                  # Viewer token from manage.sanity.io -> API -> Tokens
SANITY_REVALIDATE_SECRET=          # Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RESEND_API_KEY=                    # From resend.com dashboard -> API Keys
ORG_EMAIL=                         # Organisation email for receiving form submissions
RESEND_FROM=                       # Resend verified sender (e.g. noreply@seputehhyo.org) — falls back to onboarding@resend.dev
NEXT_PUBLIC_SITE_URL=              # Canonical base URL (e.g. https://seputehhyo.org) — used in sitemap.xml and OG tags
